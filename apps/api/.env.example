# Servidor
PORT=3000
SERVE_STATIC=../../web/dist

# JWT — gera automaticamente se não setado, mas recomendado fixar em produção
PANEL_JWT_SECRET=

# Token para chamadas internas (scheduler, auto-generate) — gera automaticamente se não setado
INTERNAL_TOKEN=

# CORS — origens permitidas separadas por vírgula. Deixar vazio = permite qualquer origem (dev only)
CORS_ORIGIN=https://social.liveuni.com.br

# Claude / Anthropic (para agentes com IA real)
ANTHROPIC_API_KEY=

# Nano Banana (geração de imagens)
NANO_BANANA_API_KEY=

# ElevenLabs (text-to-speech)
ELEVENLABS_API_KEY=

# HeyGen (talking-head videos)
HEYGEN_API_KEY=
HEYGEN_AVATAR_ID=

# Google APIs (Calendar, Drive)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/v1/auth/google/callback
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_CALENDAR_ID=

# Scheduler
SCHEDULER_AUTO_PUBLISH=false

# Veo 3 (geração de vídeo Google)
VEO_PROJECT_ID=
VEO_LOCATION=us-central1
